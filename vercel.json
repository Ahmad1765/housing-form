{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/style.css",
      "destination": "/style.css"
    },
    {
      "source": "/(submit|api|export|admin|result)",
      "destination": "/server.js"
    },
    {
      "source": "/",
      "destination": "/server.js"
    }
  ]
}
